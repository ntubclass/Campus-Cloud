# ai-pve-log 專屬設定
# 這些設定應加入專案根目錄的 .env（Campus-Cloud/.env）
# Proxmox 連線設定已與主系統共用，無需重複設定

# 服務監聽 port（選用不常用 port，避免與其他服務衝突）
# backend: 8000  frontend: 5173/5174  vLLM: 8000  FRP: 7000
PVE_LOG_PORT=18042

# 批量收集行為
COLLECTOR_MAX_WORKERS=8
COLLECTOR_FETCH_CONFIG=true
COLLECTOR_FETCH_LXC_INTERFACES=true
COLLECTOR_RETRY_ATTEMPTS=3
COLLECTOR_RETRY_BACKOFF=0.3

# ── SSH 遠端執行設定 ───────────────────────────────────────────────────────
# SSH 憑證來源：自動使用以下兩個已存在的全域變數，無需重複設定
#   FIRST_SUPERUSER           （Campus Cloud 管理員帳號 email）
#   FIRST_SUPERUSER_PASSWORD  （Campus Cloud 管理員密碼）
#
# SSH 連線到 Campus Cloud 後端的 URL（取 SSH key 用）：
#   獨立子服務需透過 HTTP 回呼主後端取得 VM IP 與 SSH key
#   請將 AI_API_PUBLIC_BASE_URL 設為主後端對外可達位址
#   （預設 http://localhost:8000，同機部署適用）
#   若主後端內嵌的 ai-pve-log 模組則走內部 DB 查詢，不使用此變數
#   AI_API_PUBLIC_BASE_URL  （已在全域 .env 設定，預設 http://localhost:8000）
#
# SSH 行為調整（以下為選填，有預設值）：

# SSH host key 驗證（true = 關閉驗證，適合內網信任環境；false = 嚴格驗證）
SSH_INSECURE_HOST_KEY=true

# SSH 預設登入帳號
SSH_DEFAULT_USER=root

# SSH 連線超時秒數
SSH_TIMEOUT=30
