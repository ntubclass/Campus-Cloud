# Domain
# This would be set to the production domain with an env var on deployment
# used by Traefik to transmit traffic and aqcuire TLS certificates
DOMAIN=localhost
# To test the local Traefik config
# DOMAIN=localhost.tiangolo.com

# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=http://localhost:5173
# In staging and production, set this env var to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="Campus Cloud"
STACK_NAME=campus-cloud

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173,http://localhost.tiangolo.com"
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Gateway VM internal Traefik API address (queried over SSH by the backend)
TRAEFIK_API_BASE_URL=http://127.0.0.1:8080
TRAEFIK_API_TIMEOUT=10

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

SENTRY_DSN=

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# System AI
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=vllm-secret-key-change-me
VLLM_MODEL_NAME=Qwen/Qwen3-Coder-Next-FP8

# ===== AI API 整合配置 =====

# VLLM Gateway 配置（内网地址）
# 指向 VLLM Gateway 的地址，Backend 会将请求代理到这里
AI_API_BASE_URL=http://localhost:3000

# VLLM API 密钥（Backend 调用 VLLM 时使用）
# 这个密钥需要与 vllm-API/.env 中的 API_KEY 一致
AI_API_API_KEY=Your_Secure_VLLM_Key_Change_Me

# 请求超时时间（秒）
# 建议设置较长的超时时间，因为模型推理可能需要较长时间
AI_API_TIMEOUT=120

# 速率限制配置
# 每个用户每分钟最多可以请求多少次
AI_API_RATE_LIMIT_PER_MINUTE=20

# 速率限制时间窗口（秒）
# 通常保持 60 秒即可
AI_API_RATE_LIMIT_WINDOW_SECONDS=60

# Redis 配置（用於 AI API 速率限制）
# 是否啟用 Redis 監控（true/false）
# 設為 false 時，後端會跳過 Redis 連接，速率限制功能將被禁用
# 開發環境建議設為 false，生產環境建議設為 true
REDIS_ENABLED=false

# Redis 連接字串
# 格式：redis://[username:password@]host:port/db
# 只有在 REDIS_ENABLED=true 時才需要配置
REDIS_URL=redis://localhost:6379/0

# AI API 對外公開 URL（供外部 AI 服務 / 用戶存取 AI proxy）
# 注意：主後端內嵌的 ai-pve-log SSH 模組已不再使用此變數做 HTTP 回呼
# 生產環境應設為實際對外可達的域名，例如：https://api.campus-cloud.com
AI_API_PUBLIC_BASE_URL=http://localhost:5000

# ===== AI-PVE-LOG SSH 遠端執行設定 =====
# 主後端內嵌模組（backend/app/ai/pve_log/）：
#   - 直接透過資料庫查詢 VM IP 與 SSH key，不再依賴 AI_API_PUBLIC_BASE_URL
#   - 不需要額外設定 HTTP 回呼位址
# 獨立 ai-pve-log 子服務：
#   - 仍需透過 AI_API_PUBLIC_BASE_URL HTTP 回呼主後端取得 JWT / IP / SSH key
#   - 獨立部署時請將 AI_API_PUBLIC_BASE_URL 設為主後端可達位址
# SSH 憑證來源：自動使用以下兩個已存在的全域變數，無需重複設定
#   FIRST_SUPERUSER           （Campus Cloud 管理員帳號 email）
#   FIRST_SUPERUSER_PASSWORD  （Campus Cloud 管理員密碼）

# SSH host key 驗證（true = 關閉驗證，適合內網信任環境；false = 嚴格驗證）
SSH_INSECURE_HOST_KEY=true

# SSH 預設登入帳號
SSH_DEFAULT_USER=root

# SSH 連線超時秒數
SSH_TIMEOUT=30
